# ---- Pappers Immobilier ----
# Clé API (https://immobilier.pappers.fr/api). Laisser vide => mode "mock" (fixtures).
PAPPERS_API_KEY=
PAPPERS_BASE_URL=https://api-immobilier.pappers.fr/v1

# ---- Base de données ----
# SQLite par défaut (zéro config). Pour Postgres :
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/immobilier
DATABASE_URL=sqlite:///./immobilier.db

# ---- Scheduler (recherches fréquentes) ----
SCHEDULER_ENABLED=true
# Intervalle (secondes) entre deux passages du scheduler qui déclenche les recherches dues.
SCHEDULER_TICK_SECONDS=300

# ---- Maîtrise des crédits Pappers ----
# Bases incluses par défaut dans une recherche (séparées par des virgules).
# "ventes" = 2 crédits/parcelle mais indispensable pour afficher prix/surface.
DEFAULT_BASES=ventes
# Plafond d'appels Pappers par exécution (garde-fou anti-conso).
MAX_PAGES_PER_RUN=5
# Durée de vie du cache des réponses Pappers (secondes).
CACHE_TTL_SECONDS=3600

# ---- Scraping ----
# Proxy (http(s)://user:pass@host:port) pour les sites protégés (Leboncoin, SeLoger...).
PROXY_URL=
# Délai mini entre deux requêtes d'une même source (anti-blocage).
SCRAPER_RATE_LIMIT_MS=2000

# ---- Divers ----
HTTP_TIMEOUT_SECONDS=20
# Origines autorisées pour le futur front (CORS), séparées par des virgules.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
